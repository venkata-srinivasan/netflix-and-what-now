# Required: Google Gemini API key (FREE — get one at https://aistudio.google.com/apikey)
# Gemini 2.0 Flash has a generous free tier: 15 RPM, 1M TPM, with vision support
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: TMDB API key for show/movie metadata (free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Optional: VocalBridge AI key for premium voice agent (https://vocalbridgeai.com)
VOCALBRIDGE_API_KEY=

# Optional: OpenAI API key if you prefer GPT-4o over Gemini (paid)
OPENAI_API_KEY=
